#include <iostream>
using namespace std;

int main() {

    int vetor[5];
    int soma = 0;
    float media;

    cout << "Digite 5 numeros:" << endl;

    for(int i = 0; i < 5; i++) {
        cout << "Numero " << i + 1 << ": ";
        cin >> vetor[i];
        soma += vetor[i];
    }

    media = soma / 5.0;

    cout << "Soma dos elementos: " << soma << endl;
    cout << "Media dos elementos: " << media << endl;

    return 0;
}