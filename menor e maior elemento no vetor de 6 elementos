#include <iostream>
using namespace std;

int main() {

    int vetor[6];
    int maior, menor;

    cout << "Digite 6 numeros:" << endl;

    for(int i = 0; i < 6; i++) {
        cout << "Numero " << i + 1 << ": ";
        cin >> vetor[i];
    }

    maior = vetor[0];
    menor = vetor[0];

    for(int i = 1; i < 6; i++) {
        if(vetor[i] > maior) {
            maior = vetor[i];
        }

        if(vetor[i] < menor) {
            menor = vetor[i];
        }
    }

    cout << "Maior numero: " << maior << endl;
    cout << "Menor numero: " << menor << endl;

    return 0;
}